# prev used light theme: Bluloco Light
theme = dark:GitHub Dark Colorblind,light:GitHub Light Colorblind
font-family = Fira Code
#background-opacity = 0.8
background-blur-radius = 20

window-width = 150
window-height = 75

# nice round corners and no useless titlebar
macos-titlebar-style = native
window-padding-x = 10
window-padding-y = 10

# avoid invisible text (like black on black)
#minimum-contrast = 1.1

adjust-cursor-thickness=3
adjust-cursor-height=20%

# block cmd+backspace line-kill globally (was wiping Claude Code input)
keybind = cmd+backspace=ignore

# safari style tab switch
keybind = cmd+alt+left=previous_tab
keybind = cmd+alt+right=next_tab
